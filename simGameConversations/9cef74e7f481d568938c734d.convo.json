    {
      "idRef": {
        "id": "9cbb9bd1c670ef24f689b5e8"
      },
      "index": 4,
      "text": "We will return to Davion space and find another suitable world to finish our holovid.\n\nYour company isn't invited for obvious reasons, but you will get full pay for your work so far.",
      "branches": [
