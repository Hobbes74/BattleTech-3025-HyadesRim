    {
      "idRef": {
        "id": "9c77d71ce8c22264db64a726"
      },
      "index": 5,
      "text": "As needed for what? What do you propose then? ",
      "branches": [
        {
          "responseText": "",
          "conditions": null,
          "actions": null,
          "nextNodeIndex": 6,
          "hideIfUnavailable": true,
          "onlyOnce": false,
