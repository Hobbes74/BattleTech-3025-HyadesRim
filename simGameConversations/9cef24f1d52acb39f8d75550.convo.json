    {
      "idRef": {
        "id": "9cd2c00f1075b805581c34eb"
      },
      "index": 6,
      "text": "Your defense plans for this world are garbage because they assume that your raiders will follow any laws of war.\n\nThe raider fleet might as well arrive in orbit and begin conducting orbital bombardments and terror raids to force you Aurigans to respond and spread your forces. ",
      "branches": [
        {
          "responseText": "",
          "conditions": null,
          "actions": null,
          "nextNodeIndex": 7,
          "hideIfUnavailable": true,
          "onlyOnce": false,
