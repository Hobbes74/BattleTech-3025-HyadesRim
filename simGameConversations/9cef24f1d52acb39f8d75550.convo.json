      "speaker_override_id": "",
      "actions": null,
      "comment": ""
    },
    {
      "idRef": {
        "id": "9cee5eb98aecb29f13e94fcf"
      },
      "index": 7,
      "text": "Because that's what would do?\n\nWhat you are saying is nonsense.",
      "branches": [
        {
          "responseText": "",
          "conditions": null,
          "actions": null,
          "nextNodeIndex": 8,
