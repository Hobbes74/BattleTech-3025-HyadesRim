    {
      "idRef": {
        "id": "9c0fd5b1a8c9397b94932fff"
      },
      "index": 3,
      "text": "Now Coromodir is the most populous and rich world of the Aurigan Reach, which makes it such a target for those Periphery marauders.\n\nThis also makes it challenging to defend because of the multitude of targets, although the presence of the <i>Argo</i> gives us a small tactical advantage to quickly redeploy the company. ",
      "branches": [
        {
          "responseText": "",
          "conditions": null,
          "actions": null,
          "nextNodeIndex": 4,
          "hideIfUnavailable": true,
          "onlyOnce": false,
          "idRef": {
            "id": "9c851fce3d78af6f485a3beb"
          },
