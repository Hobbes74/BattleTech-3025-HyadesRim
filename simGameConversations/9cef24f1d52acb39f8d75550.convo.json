    {
      "idRef": {
        "id": "9c178d03e1ba9cb626b9498e"
      },
      "index": 2,
      "text": "Commander this is not the time to discuss such matters, and you are welcome to leave if you do not like our battle plan or if you want to reveal all of our secrets to the enemy, Captain Murray!",
      "branches": [
        {
          "responseText": "",
          "conditions": null,
          "actions": null,
