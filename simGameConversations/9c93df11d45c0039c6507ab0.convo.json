    {
      "idRef": {
        "id": "9cbcc68bf521a899e0a5967d"
      },
      "index": 1,
      "text": "We were still under the employ of House Arano when the Concordat ordered us off Taurian space, this time we have a contract from Taurus Majoris Mining to clear a hostile lance on the planet.\n\nAnd a real contract, unlike the one at Diik.",
      "branches": [
        {
          "responseText": "",
          "conditions": null,
          "actions": null,
          "nextNodeIndex": 2,
          "hideIfUnavailable": true,
          "onlyOnce": false,
          "idRef": {
            "id": "9c0346075bf63694141642f4"
          },
          "inputBypass": false,
          "auxiliaryLink": false,
          "comment": ""
        }
      ],
      "nodeType": 1,
      "truthValue": false,
      "autoFollowBranchDelay": 1,
      "inputMaxLength": 0,
      "sourceTopicRef": null,
      "subjectTopicRefs": [],
      "sourceInSceneRef": null,
