    {
      "idRef": {
        "id": "9c2d9569ea883a937b969707"
      },
      "index": 3,
      "text": "Negative Chief Yang, ComStar uses a different technology and they are heavily encrypted, plus there's a strong risk that any house might suffer an interdiction if they attempt to interfere with their monopoly on interstellar communications.\n\nAnd just the existence of this device is a huge potential threat to them.",
      "branches": [
        {
          "responseText": "",
          "conditions": null,
          "actions": null,
          "nextNodeIndex": 4,
          "hideIfUnavailable": true,
          "onlyOnce": false,
          "idRef": {
            "id": "9cb857f22b49073af92e02fa"
          },
          "inputBypass": false,
          "auxiliaryLink": false,
          "comment": ""
        }
      ],
      "nodeType": 1,
      "truthValue": false,
      "autoFollowBranchDelay": 1,
