      "speaker_override_id": "",
      "actions": null,
      "comment": ""
    },
    {
      "idRef": {
        "id": "9c55c0967fd38fee5206d90c"
      },
      "index": 4,
      "text": "It's also a potential threat to us, if it becomes known that we are in possession of such an object.\n\nThis device should be either destroyed or given to someone else, since we have no use for it.",
      "branches": [
        {
          "responseText": "House Kurita would pay nicely for it since the Davions already got it.",
          "conditions": null,
          "actions": null,
          "nextNodeIndex": 5,
          "hideIfUnavailable": true,
          "onlyOnce": false,
          "idRef": {
            "id": "9c87c20f2e68453411e99a88"
          },
          "inputBypass": false,
          "auxiliaryLink": false,
          "comment": ""
        }
      ],
      "nodeType": 1,
      "truthValue": false,
