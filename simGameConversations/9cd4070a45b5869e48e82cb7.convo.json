    {
      "idRef": {
        "id": "9ce95da9c4d7a3729697b089"
      },
      "index": 2,
      "text": "Can't you listen to ComStar's HPG transmissions with it?\n\nThere might be other such devices operating out there, we just haven't been listening enough to hear their transmissions.",
      "branches": [
        {
          "responseText": "",
          "conditions": null,
          "actions": null,
