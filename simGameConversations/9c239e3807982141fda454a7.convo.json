    {
      "idRef": {
        "id": "9c0478cc44311c4a31f9ae64"
      },
      "index": 1,
      "text": "This is not over, you mercenaries need to return to the face of the planet and eliminate the remaining drone 'Mechs.\n\nWe can't risk our technology falling into the wrong hands!",
      "branches": [
        {
          "responseText": "",
          "conditions": null,
          "actions": null,
