    {
      "idRef": {
        "id": "9cca93b483dcc8eef05c4849"
      },
      "index": 5,
      "text": "Sweet pie, you can be whomever you want, as long as you are able to take me off this planet before the Taurian Constabulary locates me.\n\nIf I tell you about the Lone Wolves, do we have a deal to take me to the next system?",
      "branches": [
        {
          "responseText": "Since you mentioned, why are the Taurians after you?",
          "conditions": null,
          "actions": null,
          "nextNodeIndex": 6,
          "hideIfUnavailable": true,
          "onlyOnce": false,
          "idRef": {
