    {
      "idRef": {
        "id": "9ce533b7d0f6de97be3db22a"
      },
      "index": 11,
      "text": "May the [[DM.BaseDescriptionDefs[LoreUnfinishedBookMovement],Unfinished Book]] forbid us from insufficient social conventions... you must be Commander {COMMANDER.LastName} correct?\n\nThe proper way to address nobility in civilized space is 'your Grace' or 'Duke of Macintosh' or just 'Duke Roberts' will suffice.",
      "branches": [
        {
          "responseText": "We are not in civilized space... your Grace.",
          "conditions": null,
          "actions": null,
          "nextNodeIndex": 12,
          "hideIfUnavailable": true,
          "onlyOnce": false,
          "idRef": {
            "id": "9cf7b53a214074d77c6a720c"
          },
