    {
      "idRef": {
        "id": "9cf332532fde04ed41cfd2da"
      },
      "index": 12,
      "text": "That's expected from your background... I will brief you all now on your contract without wasting more of my time.\n\nAs you may know, the [[DM.BaseDescriptionDefs[LoreFedComAccords],FedCom Accords]] allowed for a wealth of knowledge to be shared between the [[DM.Factions[faction_Davion],Federated Suns]] and the [[DM.Factions[faction_Steiner],Lyrans]].",
      "branches": [
        {
          "responseText": "",
          "conditions": null,
          "actions": null,
          "nextNodeIndex": 13,
          "hideIfUnavailable": true,
          "onlyOnce": false,
          "idRef": {
            "id": "9cf129febecdc2b0c557766a"
          },
          "inputBypass": false,
          "auxiliaryLink": false,
          "comment": ""
        }
      ],
      "nodeType": 1,
      "truthValue": false,
      "autoFollowBranchDelay": 1,
      "inputMaxLength": 0,
      "sourceTopicRef": null,
      "subjectTopicRefs": [],
      "sourceInSceneRef": {
